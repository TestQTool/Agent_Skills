{
  "framework": {
    "tool": "Appium",
    "language": "Java",
    "framework": "TestNG Framework",
    "runner": "TestNG",
    "project": "appium-java-testng",
    "command": "mvn test -Dgroups=smoke -DplatformName=Android",
    "iosCommand": "mvn test -Dgroups=smoke -DplatformName=iOS"
  },
  "testng": {
    "groups": [
      "smoke",
      "regression"
    ],
    "dataProvider": true,
    "listeners": true
  }
}
