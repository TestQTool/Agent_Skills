{
  "framework": {
    "tool": "Robot Framework",
    "language": "Robot",
    "framework": "Appium Library",
    "project": "robotframework-appiumlibrary",
    "androidCommand": "robot -i smoke -v PLATFORM:Android tests",
    "iosCommand": "robot -i smoke -v PLATFORM:iOS tests"
  },
  "platforms": [
    "Android",
    "iOS"
  ],
  "capabilities": {
    "Android": [
      "platformName",
      "automationName",
      "deviceName",
      "appPackage/appActivity or app"
    ],
    "iOS": [
      "platformName",
      "automationName",
      "deviceName/udid",
      "platformVersion",
      "bundleId or app"
    ]
  }
}
