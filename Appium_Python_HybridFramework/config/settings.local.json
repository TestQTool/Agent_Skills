{
  "framework": {
    "tool": "Appium",
    "language": "Python",
    "framework": "Hybrid Framework",
    "project": "appium-python-hybrid",
    "androidCommand": "pytest -m smoke --platform Android",
    "iosCommand": "pytest -m smoke --platform iOS"
  },
  "platforms": [
    "Android",
    "iOS"
  ],
  "capabilities": {
    "Android": [
      "platformName",
      "automationName",
      "deviceName",
      "appPackage/appActivity or app"
    ],
    "iOS": [
      "platformName",
      "automationName",
      "deviceName/udid",
      "platformVersion",
      "bundleId or app"
    ]
  }
}
